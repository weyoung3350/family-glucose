.about-page { text-align: center; padding-top: 70rpx; }
.logo { width: 180rpx; height: 180rpx; display: block; margin: 0 auto; }
.name { font-size: 44rpx; font-weight: 900; margin-top: 26rpx; }
.version { color: #86909C; margin: 12rpx 0 40rpx; }
.menu { text-align: left; }
.menu > view { display: flex; justify-content: space-between; padding: 26rpx 0; border-bottom: 1rpx solid #F2F3F5; }
.changelog { margin-top: 24rpx; text-align: left; }
.log-title { font-size: 30rpx; font-weight: 800; color: #1D2129; margin-bottom: 14rpx; }
.log-text { font-size: 26rpx; line-height: 1.7; color: #4E5969; }
.notice { color: #86909C; line-height: 1.7; margin-top: 80rpx; padding: 0 40rpx; }
