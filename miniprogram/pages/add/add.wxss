.add-page { padding-bottom: 140rpx; }
.segment { background: #FFFFFF; border-radius: 999rpx; padding: 8rpx; display: grid; grid-template-columns: 1fr 1fr; margin-bottom: 24rpx; }
.segment > view { height: 76rpx; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; color: #86909C; }
.segment .active { background: #FF9F40; color: #FFFFFF; font-weight: 800; }
.field-label { color: #4E5969; font-size: 30rpx; margin-bottom: 18rpx; }
.field-hint { color: #86909C; font-size: 24rpx; font-weight: 400; }
.field-warn { color: #F5222D; font-size: 26rpx; margin-top: 14rpx; }
.value-row { display: flex; align-items: center; gap: 14rpx; }
.value-input { height: 82rpx; font-size: 68rpx; line-height: 82rpx; font-weight: 800; color: #FF9F40; flex: 1; }
.value-placeholder { color: #C9CDD4; font-size: 56rpx; font-weight: 600; }
.unit { color: #86909C; font-size: 30rpx; }
.picker-line { font-size: 34rpx; color: #1F2329; padding: 16rpx 0; }
.note-input { height: 76rpx; font-size: 32rpx; }
.save-bar { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(env(safe-area-inset-bottom) + 20rpx); }

/* AI 模式 */
.ai-tip { color: #4E5969; font-size: 28rpx; line-height: 1.6; text-align: center; padding: 18rpx 12rpx; }
.ai-transcribed { background: #FFF7ED; border-radius: 18rpx; padding: 20rpx 24rpx; margin: 8rpx 0 20rpx; }
.ai-transcribed-label { display: block; color: #86909C; font-size: 24rpx; margin-bottom: 8rpx; }
.ai-transcribed-text { font-size: 32rpx; color: #1F2329; line-height: 1.5; }
.voice-btn-big { display: flex; align-items: center; justify-content: center; gap: 18rpx; height: 140rpx; border-radius: 999rpx; background: #FF9F40; color: #FFFFFF; font-size: 38rpx; font-weight: 800; box-shadow: 0 16rpx 34rpx rgba(255,159,64,.35); margin-top: 12rpx; user-select: none; transition: background .15s ease; }
.voice-btn-big.recording { background: #F5222D; box-shadow: 0 16rpx 34rpx rgba(245,34,45,.4); }
.voice-btn-big.cancelling { background: #86909C; box-shadow: 0 16rpx 34rpx rgba(31,35,41,.25); }
.voice-btn-big .voice-dot { width: 18rpx; height: 18rpx; border-radius: 50%; background: #FFFFFF; flex-shrink: 0; }
.voice-btn-big.recording .voice-dot { animation: voicePulse 0.8s infinite; }
@keyframes voicePulse { 0%,100% { transform: scale(1); opacity: 1 } 50% { transform: scale(1.6); opacity: .5 } }
.error,.missing { color: #F5222D; font-size: 28rpx; margin-top: 14rpx; }
.missing { background: #FFF1F0; padding: 18rpx 24rpx; border-radius: 18rpx; margin-bottom: 20rpx; }
.card-title { color: #86909C; font-size: 28rpx; margin-bottom: 12rpx; }
.result-row { display: flex; justify-content: space-between; padding: 24rpx 0; border-bottom: 1rpx solid #F2F3F5; }
.result-row.inferred { background: #FFFBE6; border-left: 6rpx solid #FAAD14; padding-left: 18rpx; margin-left: -18rpx; padding-right: 18rpx; }
.value { color: #FF9F40; font-weight: 800; }
.infer-badge { background: #FAAD14; color: #FFFFFF; font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 8rpx; margin-left: 8rpx; font-weight: 600; }
.period-edit .periods { margin: 10rpx 0 20rpx; }
.bottom-actions { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(env(safe-area-inset-bottom) + 20rpx); display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.disabled { opacity: .45; }
