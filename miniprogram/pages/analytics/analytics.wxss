.segment { background: #FFFFFF; border-radius: 999rpx; padding: 8rpx; display: grid; grid-template-columns: 1fr 1fr 1fr; margin-bottom: 24rpx; }
.segment > view { height: 76rpx; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; color: #86909C; }
.segment .active { background: #FF9F40; color: #FFFFFF; font-weight: 800; }
.matrix { overflow-x: scroll; }
.matrix-tip { color: #86909C; font-size: 24rpx; text-align: center; margin-bottom: 14rpx; }
.matrix-head,.matrix-row { display: grid; grid-template-columns: 150rpx repeat(8, 88rpx); gap: 10rpx; align-items: center; min-width: 870rpx; }
.matrix-head { color: #86909C; font-size: 26rpx; margin-bottom: 12rpx; }
.matrix-row { margin-bottom: 12rpx; }
.date { font-size: 26rpx; color: #4E5969; }
.cell { height: 88rpx; border-radius: 14rpx; color: #FFFFFF; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; }
.chips { display: flex; gap: 14rpx; margin-bottom: 18rpx; }
.chips > view { background: #FFFFFF; border-radius: 999rpx; padding: 16rpx 24rpx; color: #4E5969; }
.chips .active { background: #FF9F40; color: #FFFFFF; }
.chart-box { height: 520rpx; position: relative; padding: 0; overflow: hidden; }
.trend-canvas { width: 100%; height: 520rpx; display: block; }
.empty-chart { position: absolute; left: 0; right: 0; top: 220rpx; text-align: center; color: #86909C; font-size: 30rpx; }
.stats > view,.period-stat { display: flex; justify-content: space-between; padding: 18rpx 0; border-bottom: 1rpx solid #F2F3F5; }
.distribution { margin-top: 18rpx; }
.dist-title { font-size: 34rpx; font-weight: 800; margin-bottom: 18rpx; color: #1D2129; }
.dist-bar { height: 28rpx; border-radius: 999rpx; overflow: hidden; background: #F2F3F5; display: flex; margin-bottom: 18rpx; }
.dist-bar > view { min-width: 0; height: 100%; }
.dist-row { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; color: #4E5969; font-size: 28rpx; }
.dist-name { display: flex; align-items: center; }
.dist-dot { width: 18rpx; height: 18rpx; border-radius: 50%; margin-right: 10rpx; }
.report-hero { background: linear-gradient(135deg, #FFB066, #FF9F40); border-radius: 32rpx; padding: 36rpx; color: #FFFFFF; margin-bottom: 22rpx; }
.avg { font-size: 86rpx; font-weight: 900; margin: 10rpx 0; }
