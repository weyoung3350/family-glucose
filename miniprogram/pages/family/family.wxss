.family-name { display: flex; justify-content: space-between; align-items: center; }
.label { color: #86909C; font-size: 28rpx; margin-bottom: 10rpx; }
.name { font-size: 38rpx; font-weight: 900; }
.edit { color: #F08A2C; }
.code { display: block; font-size: 58rpx; font-weight: 900; letter-spacing: 10rpx; color: #FF9F40; text-align: center; margin: 28rpx 0; font-family: SF Mono, Menlo, Monaco, Consolas, monospace; user-select: text; -webkit-user-select: text; }
.invite-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.share-btn { height: 88rpx; border-radius: 44rpx; background: #FF9F40; color: #FFFFFF; display: flex; align-items: center; justify-content: center; font-size: 30rpx; }
.section-title { font-weight: 900; margin-bottom: 16rpx; }
.member { display: flex; align-items: center; gap: 18rpx; padding: 20rpx 0; border-bottom: 1rpx solid #F2F3F5; }
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: #FFF3E8; color: #F08A2C; display: flex; align-items: center; justify-content: center; font-weight: 900; }
.member-main { flex: 1; }
.role { color: #FF9F40; font-size: 24rpx; background: #FFF3E8; padding: 4rpx 12rpx; border-radius: 999rpx; }
.joined { color: #86909C; font-size: 24rpx; margin-top: 8rpx; }
.remove { color: #F5222D; font-size: 26rpx; padding: 10rpx 22rpx; border: 1rpx solid #FFCCC7; border-radius: 999rpx; background: #FFFFFF; }
.danger-btn { height: 92rpx; border-radius: 46rpx; border: 1rpx solid #F5222D; color: #F5222D; display: flex; align-items: center; justify-content: center; background: #FFFFFF; margin-top: 28rpx; }
.tip { color: #86909C; font-size: 26rpx; text-align: center; margin-top: 22rpx; }
