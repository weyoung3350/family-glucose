.home-page { padding-bottom: 150rpx; }
.offline-banner { background: #FFF7E6; color: #874D00; border-left: 6rpx solid #FAAD14; padding: 18rpx 24rpx; border-radius: 14rpx; margin-bottom: 18rpx; font-size: 26rpx; }
.hero { background: linear-gradient(135deg, #FFB066, #FF9F40); border-radius: 32rpx; padding: 34rpx; color: #FFFFFF; display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; }
.title { font-size: 40rpx; font-weight: 800; }
.subtitle { margin-top: 12rpx; font-size: 28rpx; opacity: .9; }
.today-stat { width: 132rpx; height: 132rpx; border-radius: 50%; background: rgba(255,255,255,.22); display: flex; flex-direction: column; justify-content: center; align-items: center; }
.num { font-size: 48rpx; font-weight: 900; }
.lbl { font-size: 24rpx; }
.day-label { color: #86909C; font-size: 28rpx; margin: 26rpx 0 14rpx; }
.empty { margin-top: 160rpx; color: #4E5969; display: flex; flex-direction: column; align-items: center; gap: 14rpx; }
.drop { width: 112rpx; height: 112rpx; border-radius: 32rpx; background: #FFE4C7; color: #F08A2C; font-size: 52rpx; font-weight: 900; display: flex; align-items: center; justify-content: center; }
.hint,.end-tip { color: #86909C; font-size: 28rpx; text-align: center; }
.fab-row { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(env(safe-area-inset-bottom) + 24rpx); display: flex; gap: 20rpx; align-items: center; }
.fab-main { flex: 1; height: 104rpx; border-radius: 52rpx; background: #FF9F40; color: #FFFFFF; display: flex; align-items: center; justify-content: center; font-size: 36rpx; font-weight: 800; box-shadow: 0 16rpx 34rpx rgba(255,159,64,.35); }
.fab-ai { width: 184rpx; height: 104rpx; border-radius: 52rpx; background: #FFFFFF; color: #FF9F40; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 700; box-shadow: 0 14rpx 34rpx rgba(31,35,41,.12); border: 2rpx solid #FFD9A8; }
