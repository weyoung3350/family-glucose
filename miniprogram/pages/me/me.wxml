<view class="page me-page">
  <view class="profile" bindtap="editNickname">
    <view class="avatar">{{avatarText}}</view>
    <view class="profile-main">
      <view class="nickname">{{user.nickname || '设置昵称'}}<text class="edit-hint">› 编辑</text></view>
      <view class="family">{{family.name || '未加入家庭'}} · {{roleText}}</view>
    </view>
  </view>
  <view class="menu card">
    <view class="menu-item" bindtap="goFamily"><view class="icon">家</view><text class="menu-text">家庭管理</text><text class="arrow">›</text></view>
    <view class="menu-item" bindtap="goStandards"><view class="icon">设</view><text class="menu-text">自定义血糖标准</text><text class="arrow">›</text></view>
    <view class="menu-item" bindtap="goExport"><view class="icon">导</view><text class="menu-text">数据导出</text><text class="arrow">›</text></view>
    <view class="menu-item" bindtap="goAbout"><view class="icon">i</view><text class="menu-text">关于</text><text class="arrow">›</text></view>
  </view>
</view>
